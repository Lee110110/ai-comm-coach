# 应用配置
APP_NAME=AI沟通教练
DEBUG=true

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# LLM 配置 (OpenAI 兼容接口)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
